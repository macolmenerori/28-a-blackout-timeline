{
  "name": "28-a-blackout-timeline",
  "version": "1.1.1",
  "type": "module",
  "description": "Full timeline of the blackout that affected Spain and Portugal on April 28, 2025.",
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "macolmenerori",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/macolmenerori/28-a-blackout-timeline"
  },
  "scripts": {
    "dev": "vite-react-ssg dev",
    "build": "tsx scripts/generate-sitemap.ts && tsc -b && vite-react-ssg build",
    "prettify": "prettier -w --log-level=silent src/",
    "preview": "vite preview",
    "lint": "eslint --fix ./src/",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "verify": "pnpm audit --prod && pnpm lint && pnpm prettify && pnpm types && pnpm test && pnpm build",
    "release": "npx tsx scripts/release.ts"
  },
  "keywords": [
    "blackout",
    "timeline",
    "spain",
    "portugal",
    "electricity",
    "power"
  ],
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.18",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react-helmet-async": "^3.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.2",
    "vite-react-ssg": "^0.9.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@macolmenerori/component-library": "^1.4.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "swr": "^2.4.1"
  }
}
